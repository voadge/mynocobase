{
  "compilerOptions": {
    "target": "ES2020",
    "module": "amd",
    "lib": ["ES2020"],
    "outDir": "./dist/client",
    "rootDir": "./src/client",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
  },
  "include": ["src/client/**/*"],
  "exclude": ["node_modules", "dist"]
}
