.bind-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}
.header {
  padding: 48rpx 40rpx 24rpx;
  background: #fff;
}
.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}
.search-box {
  margin: 0 40rpx 16rpx;
  padding: 0 24rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 2rpx solid #e8e8e8;
  box-sizing: border-box;
}
.search-box:focus {
  border-color: #1677ff;
}
.user-list {
  flex: 1;
  padding: 0 40rpx;
}
.user-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}
.user-item:active {
  background: #f0f5ff;
}
.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1677ff;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.user-info {
  flex: 1;
  min-width: 0;
}
.user-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}
.user-dept {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
.status-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.status-text {
  font-size: 28rpx;
  color: #666;
}
.status-error {
  font-size: 28rpx;
  color: #ff4d4f;
  margin-bottom: 32rpx;
}
.retry-btn {
  width: 320rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
}
