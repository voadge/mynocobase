<view class="bind-page">
  <view class="header">
    <text class="title">选择您的账号</text>
    <text class="desc">在下方找到您的姓名并点击确认绑定</text>
  </view>

  <input class="search-box" placeholder="搜索姓名或部门..." value="{{search}}" bindinput="onSearch" />

  <scroll-view class="user-list" scroll-y wx:if="{{!loading && !error}}">
    <view class="user-item" wx:for="{{filteredUsers}}" wx:key="id" data-id="{{item.id}}" bindtap="selectUser">
      <view class="user-avatar">{{item.nickname ? item.nickname.slice(0,1) : '?'}}</view>
      <view class="user-info">
        <text class="user-name">{{item.nickname}}</text>
        <text class="user-dept">{{item.department || '未分配部门'}}</text>
      </view>
    </view>
    <view wx:if="{{filteredUsers.length === 0}}" class="empty">无匹配用户</view>
  </scroll-view>

  <view wx:elif="{{loading}}" class="status-wrap">
    <view class="loading-spinner"></view>
    <text class="status-text">加载用户列表...</text>
  </view>

  <view wx:elif="{{error}}" class="status-wrap">
    <text class="status-error">{{error}}</text>
    <button class="retry-btn" bindtap="fetchUsers">重试</button>
  </view>
</view>
