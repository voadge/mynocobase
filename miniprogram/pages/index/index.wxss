.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
  padding: 40rpx;
}
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #666;
}
.bind-tip, .error-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.bind-icon, .error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.bind-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.bind-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.error-text {
  font-size: 28rpx;
  color: #ff4d4f;
  margin-bottom: 40rpx;
}
.bind-btn, .retry-btn {
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.retry-btn {
  background: #ff4d4f;
}
