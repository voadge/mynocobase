<web-view wx:if="{{webviewUrl}}" src="{{webviewUrl}}"></web-view>
<view wx:else class="loading-wrap">
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在登录...</text>
  </view>
  <view wx:elif="{{needBind}}" class="bind-tip">
    <text class="bind-icon">🔗</text>
    <text class="bind-title">首次使用需绑定账号</text>
    <text class="bind-desc">请先用电脑浏览器登录系统，然后扫码绑定</text>
    <button class="bind-btn" bindtap="goBind">去绑定</button>
  </view>
  <view wx:elif="{{error}}" class="error-tip">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="handleLogin">重试</button>
  </view>
</view>
